# Docker Environment Configuration
# Copy this file to .env and modify the values

# Backend API URL
# This is the URL where your CakePHP backend is running
BACKEND_API_URL=https://services.mahallu.com/api

# Frontend Port
# The port where the frontend will be accessible
FRONTEND_PORT=3000

# Optional: Site URL (for production deployments)
# SITE_URL=https://mahallu.com

# Optional: Node Environment
# NODE_ENV=production
